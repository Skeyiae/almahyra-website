// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Property {
  id              String   @id
  name            String
  titleTop        String
  titleBottom     String
  description     String?  @default("Hunian modern dan nyaman dengan lokasi strategis untuk keluarga Anda.")
  locationText    String?  @default("Lokasi Strategis")
  promoBadge      String?
  promoSubtext    String?
  landmarks       Json?    @default("[]")
  mapUrl          String?
  sitePlanImage   String?
  salesPhone      String?  @default("62895610098292")
  salesName       String?  @default("Almahyra Sales")
  imagesStandard      Json?    @default("[]")
  imagesPremium       Json?    @default("[]")
  mortgageSchemes    Json?    @default("[]")
  units              Unit[]
}

model Unit {
  id           String   @id
  propertyId   String
  label        String?  // e.g., "A-01", "B-05"
  property     Property @relation(fields: [propertyId], references: [id])
  type         String
  price        String
  status       String
  features     String[]
  bedrooms     Int?     @default(2)
  bathrooms    Int?     @default(1)
  buildingArea Int?     @default(36)
  landArea     Int?     @default(72)
  electricity  String?  @default("1300 VA")
  waterSource  String?  @default("Sumur Bor")
}
